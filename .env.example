# Required ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token-from-BotFather
ALLOWED_USER_ID=123456789

# Backend ─────────────────────────────────────────────────────────────────
# Which backend new chats default to: claude | codex | ollama
BOT_BACKEND=claude

# Claude Code
CLAUDE_MODEL=claude-opus-4-7[1m]
CLAUDE_WORKING_DIR=/Users/me

# Ollama (only used when BOT_BACKEND=ollama or /ollama is invoked)
OLLAMA_MODEL=llama3.2
OLLAMA_HOST=http://localhost:11434

# Optional ────────────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...          # enables /voice transcription (Whisper)
# XAI_API_KEY=xai-...            # enables TTS voice replies (Grok Ara)
